# Copy this to .env and fill in your key
# cp .env.example .env

# DeepSeek API key (required)
DEEPSEEK_API_KEY=sk-...

# Server config (optional — defaults shown)
HARNESS_HOST=localhost
HARNESS_PORT=8001

# Langfuse / LangSmith (optional — for observability)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
