{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-harness.local/schemas/iter_sidecar.v2.schema.json",
  "title": "Iter Sidecar v2",
  "description": "Per-(node, iter) invocation record. ADR D2 (content) + D7 (lifecycle). Required fields are minimal so legacy sidecars (no status/last_seq) still validate; lifecycle fields are added by P2b.",
  "type": "object",
  "required": ["iter", "node_id"],
  "additionalProperties": false,
  "properties": {
    "iter": {
      "type": "integer",
      "minimum": 1
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["streaming", "completed", "failed", "interrupted"],
      "description": "D7 lifecycle state. Legacy sidecars default to 'completed' (write-time)."
    },
    "last_seq": {
      "type": "integer",
      "minimum": 0,
      "description": "D7 sync point: event_bus seq at last flush. WS reconnect uses since_seq = last_seq."
    },
    "started_at": {
      "type": ["number", "string", "null"],
      "description": "Epoch seconds or ISO-8601 timestamp."
    },
    "ended_at": {
      "type": ["number", "string", "null"]
    },
    "duration_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "input_prompt": {
      "type": ["string", "null"]
    },
    "system_prompt": {
      "type": ["string", "null"]
    },
    "streaming_text": {
      "type": "string",
      "description": "D7 accumulated text_delta. Cleared on finalize."
    },
    "output_result": {
      "description": "Agent output (any shape). Null until node.completed."
    },
    "output": {
      "description": "Legacy alias for output_result. Pre-v2 sidecars use this; kept for read compat."
    },
    "input": {
      "description": "Legacy alias for input_prompt/upstream inputs."
    },
    "tool_calls": {
      "type": "array",
      "items": {"$ref": "#/$defs/tool_call"}
    },
    "todo_steps": {
      "type": "array",
      "items": {"$ref": "#/$defs/todo_step"},
      "description": "O1: per-iter todo steps filtered from snapshot.todo_states[node] by iteration === iter."
    },
    "summary": {
      "type": "string"
    },
    "tokens": {
      "type": ["object", "null"],
      "properties": {
        "input": {"type": "integer", "minimum": 0},
        "output": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "token_usage": {
      "type": ["object", "null"],
      "description": "Legacy alias for tokens."
    },
    "events_seq_range": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 2,
      "maxItems": 2
    }
  },
  "$defs": {
    "tool_call": {
      "type": "object",
      "required": ["tool_name"],
      "additionalProperties": true,
      "properties": {
        "tool_name": {"type": "string"},
        "tool_args": {"type": ["object", "string", "null"]},
        "tool_result": {"description": "Any"},
        "ts": {"type": ["number", "integer", "null"]},
        "seq": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "todo_step": {
      "type": "object",
      "required": ["task_id", "content", "status"],
      "additionalProperties": true,
      "properties": {
        "task_id": {"type": "string"},
        "content": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed"]
        },
        "activeForm": {"type": ["string", "null"]},
        "detail": {"description": "Any"},
        "iteration": {"type": ["integer", "null"], "minimum": 1}
      }
    }
  }
}
