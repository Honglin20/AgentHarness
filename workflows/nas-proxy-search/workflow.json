{
  "name": "nas-proxy-search",
  "agents": [
    {
      "name": "space_analyzer",
      "description": "分析搜索空间规模和复杂度",
      "after": []
    },
    {
      "name": "proxy_builder",
      "description": "构建 Proxy 评估器",
      "after": ["space_analyzer"]
    },
    {
      "name": "proxy_searcher",
      "description": "执行 Proxy 加速搜索",
      "after": ["proxy_builder"]
    },
    {
      "name": "report_painter",
      "description": "生成搜索结果报告",
      "after": ["proxy_searcher"]
    }
  ]
}
