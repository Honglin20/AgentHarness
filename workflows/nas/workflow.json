    {
      "name": "analyzer",
      "after": [
        "optimizer_hyperparam",
        "optimizer_structural",
        "optimizer_business"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent"
      ],
      "model": null,
      "retries": 2,
      "on_pass": "reporter",
      "on_fail": "tier2_runner",
      "result_type_name": "AnalyzerResult",
      "result_type_schema": {
