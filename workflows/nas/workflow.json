{
  "name": "nas",
  "agents": [
    {
      "name": "project_analyzer",
      "after": [],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "ProjectAnalysis",
      "result_type_schema": {
        "description": "project_analyzer output. Detects user project structure.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "model_class": {
            "title": "Model Class",
            "type": "string"
          },
          "model_module": {
            "title": "Model Module",
            "type": "string"
          },
          "model_init_args": {
            "additionalProperties": true,
            "title": "Model Init Args",
            "type": "object"
          },
          "model_init_signature": {
            "default": "",
            "title": "Model Init Signature",
            "type": "string"
          },
          "train_entry": {
            "description": "'module:function' or 'NOT_FOUND'",
            "title": "Train Entry",
            "type": "string"
          },
          "train_signature": {
            "default": "",
            "title": "Train Signature",
            "type": "string"
          },
          "eval_entry": {
            "default": "NOT_FOUND",
            "description": "Optional; new design extracts from log",
            "title": "Eval Entry",
            "type": "string"
          },
          "eval_signature": {
            "default": "",
            "title": "Eval Signature",
            "type": "string"
          },
          "weights_path": {
            "default": "NOT_FOUND",
            "title": "Weights Path",
            "type": "string"
          },
          "weights_exist": {
            "default": false,
            "title": "Weights Exist",
            "type": "boolean"
          },
          "data_loader_entry": {
            "default": "NOT_FOUND",
            "title": "Data Loader Entry",
            "type": "string"
          },
          "epochs_controllable": {
            "title": "Epochs Controllable",
            "type": "boolean"
          },
          "epochs_control_mechanism": {
            "enum": [
              "cli_flag",
              "function_arg",
              "config_file",
              "hardcoded"
            ],
            "title": "Epochs Control Mechanism",
            "type": "string"
          },
          "epochs_default": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Epochs Default"
          }
        },
        "required": [
          "summary",
          "model_class",
          "model_module",
          "train_entry",
          "epochs_controllable",
          "epochs_control_mechanism"
        ],
        "title": "ProjectAnalysis",
        "type": "object"
      }
    },
    {
      "name": "adapter_generator",
      "after": [
        "project_analyzer"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent",
        "ask_user"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "AdapterGenResult",
      "result_type_schema": {
        "description": "adapter_generator output. Generates _nas_adapter.py + validates smoke.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "adapter_path": {
            "title": "Adapter Path",
            "type": "string"
          },
          "adapter_report_path": {
            "title": "Adapter Report Path",
            "type": "string"
          },
          "smoke_pass": {
            "title": "Smoke Pass",
            "type": "boolean"
          },
          "epochs_controllable": {
            "title": "Epochs Controllable",
            "type": "boolean"
          }
        },
        "required": [
          "summary",
          "adapter_path",
          "adapter_report_path",
          "smoke_pass",
          "epochs_controllable"
        ],
        "title": "AdapterGenResult",
        "type": "object"
      }
    },
    {
      "name": "business_analyzer",
      "after": [
        "project_analyzer"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "BusinessContextResult",
      "result_type_schema": {
        "description": "business_analyzer output. Task/data/feature background for optimizer_business.\n\nReplaces the old DomainAnalysisResult. Scope expanded: not just domain\nclassification but actual business context the optimizer can act on\n(data characteristics, feature engineering hints, SOTA method suggestions).",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "business_context_path": {
            "description": "<session_dir>/business_context.md",
            "title": "Business Context Path",
            "type": "string"
          },
          "domain": {
            "description": "cv | nlp | speech | tabular | rl | wireless | timeseries | rec | unknown",
            "title": "Domain",
            "type": "string"
          },
          "task_type": {
            "description": "classification | regression | generation | detection | other",
            "title": "Task Type",
            "type": "string"
          },
          "data_characteristics": {
            "description": "Brief: size, format, modality",
            "title": "Data Characteristics",
            "type": "string"
          },
          "feature_characteristics": {
            "description": "Brief: dimensionality, structure",
            "title": "Feature Characteristics",
            "type": "string"
          },
          "sota_hints": {
            "description": "Suggested SOTA methods/structures for optimizer_business",
            "items": {
              "type": "string"
            },
            "title": "Sota Hints",
            "type": "array"
          },
          "cognition_retrieved_path": {
            "default": "",
            "description": "<session_dir>/cognition_retrieved.json",
            "title": "Cognition Retrieved Path",
            "type": "string"
          }
        },
        "required": [
          "summary",
          "business_context_path",
          "domain",
          "task_type",
          "data_characteristics",
          "feature_characteristics"
        ],
        "title": "BusinessContextResult",
        "type": "object"
      }
    },
    {
      "name": "smoke_runner",
      "after": [
        "adapter_generator"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "SmokeRunResult",
      "result_type_schema": {
        "description": "smoke_runner output. 1 epoch + small data_ratio, captures train.log.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "smoke_train_log_path": {
            "description": "<session_dir>/smoke_train.log",
            "title": "Smoke Train Log Path",
            "type": "string"
          },
          "smoke_eval_path": {
            "description": "<session_dir>/smoke_eval.json",
            "title": "Smoke Eval Path",
            "type": "string"
          },
          "smoke_pass": {
            "title": "Smoke Pass",
            "type": "boolean"
          },
          "duration_sec": {
            "title": "Duration Sec",
            "type": "number"
          }
        },
        "required": [
          "summary",
          "smoke_train_log_path",
          "smoke_eval_path",
          "smoke_pass",
          "duration_sec"
        ],
        "title": "SmokeRunResult",
        "type": "object"
      }
    },
    {
      "name": "metric_align",
      "after": [
        "smoke_runner",
        "business_analyzer"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent",
        "ask_user"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "MetricAlignResult",
      "result_type_schema": {
        "description": "metric_align output. ask_user confirms metric + direction + log parse rules.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "metric_contract_path": {
            "title": "Metric Contract Path",
            "type": "string"
          },
          "log_parse_rules_path": {
            "title": "Log Parse Rules Path",
            "type": "string"
          },
          "primary_metric": {
            "title": "Primary Metric",
            "type": "string"
          },
          "direction": {
            "enum": [
              "higher",
              "lower"
            ],
            "title": "Direction",
            "type": "string"
          },
          "user_confirmed": {
            "title": "User Confirmed",
            "type": "boolean"
          }
        },
        "required": [
          "summary",
          "metric_contract_path",
          "log_parse_rules_path",
          "primary_metric",
          "direction",
          "user_confirmed"
        ],
        "title": "MetricAlignResult",
        "type": "object"
      }
    },
    {
      "name": "setup_align",
      "after": [
        "metric_align"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent",
        "ask_user"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "SetupAlignResult",
      "result_type_schema": {
        "description": "setup_align output. SETUP phase total contract.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "setup_contract_path": {
            "description": "<session_dir>/setup_contract.json",
            "title": "Setup Contract Path",
            "type": "string"
          },
          "target_metric_value": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target Metric Value"
          },
          "time_budget_sec": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Time Budget Sec"
          },
          "care_about_latency": {
            "title": "Care About Latency",
            "type": "boolean"
          },
          "max_tier": {
            "title": "Max Tier",
            "type": "integer"
          }
        },
        "required": [
          "summary",
          "setup_contract_path",
          "target_metric_value",
          "time_budget_sec",
          "care_about_latency",
          "max_tier"
        ],
        "title": "SetupAlignResult",
        "type": "object"
      }
    },
    {
      "name": "baseline_runner",
      "after": [
        "setup_align"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent",
        "ask_user"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "FullBaselineResult",
      "result_type_schema": {
        "description": "baseline_runner (new) output. Full-epoch baseline + ask_user post-report.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "baseline_path": {
            "description": "<session_dir>/baseline.json",
            "title": "Baseline Path",
            "type": "string"
          },
          "baseline_eval_path": {
            "description": "<session_dir>/baseline_eval.json",
            "title": "Baseline Eval Path",
            "type": "string"
          },
          "full_pass": {
            "title": "Full Pass",
            "type": "boolean"
          },
          "user_confirmed": {
            "description": "ask_user confirmed continuation into NAS cycle",
            "title": "User Confirmed",
            "type": "boolean"
          }
        },
        "required": [
          "summary",
          "baseline_path",
          "baseline_eval_path",
          "full_pass",
          "user_confirmed"
        ],
        "title": "FullBaselineResult",
        "type": "object"
      }
    },
    {
      "name": "selector",
      "after": [
        "baseline_runner"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "SelectorResult",
      "result_type_schema": {
        "description": "selector output. Picks ONE parent for all 3 optimizers in this iter.\n\nBucket sampling: elite(top 1-10) → parent; diversity(top 11-50) → refs.\nHard rule: no same source 3 iters in a row (rotation).\ntier filter: elite = {T1, T2_passed}; diversity includes T2_failed.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "iter_num": {
            "title": "Iter Num",
            "type": "integer"
          },
          "parent_strategy_id": {
            "description": "'baseline' for iter 1; else top-scored from candidates",
            "title": "Parent Strategy Id",
            "type": "string"
          },
          "parent_source": {
            "description": "Which optimizer direction produced this parent (for rotation tracking)",
            "enum": [
              "baseline",
              "hyperparam",
              "structural",
              "business"
            ],
            "title": "Parent Source",
            "type": "string"
          },
          "score_components": {
            "additionalProperties": true,
            "description": "{fitness, exploration_bonus, total_score, rotation_rule_applied}",
            "title": "Score Components",
            "type": "object"
          }
        },
        "required": [
          "summary",
          "iter_num",
          "parent_strategy_id",
          "parent_source",
          "score_components"
        ],
        "title": "SelectorResult",
        "type": "object"
      }
    },
    {
      "name": "summarizer",
      "after": [
        "selector"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "SummarizerResult",
      "result_type_schema": {
        "description": "summarizer output. Macro experience review for the selected parent.\nReads parent + L0 + L1, outputs actionable guidance per optimizer direction.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "iter_num": {
            "title": "Iter Num",
            "type": "integer"
          },
          "parent_strategy_id": {
            "title": "Parent Strategy Id",
            "type": "string"
          },
          "guidance": {
            "additionalProperties": true,
            "description": "{hyperparam: str, structural: str, business: str}",
            "title": "Guidance",
            "type": "object"
          },
          "l0_recipes_retrieved": {
            "description": "List of recipe ids from L0 cognition_base",
            "items": {
              "type": "string"
            },
            "title": "L0 Recipes Retrieved",
            "type": "array"
          },
          "l0_recipes_path": {
            "default": "",
            "description": "<session_dir>/iter_<N>/cognition_retrieved.json",
            "title": "L0 Recipes Path",
            "type": "string"
          },
          "experience_appended": {
            "description": "True if L1/experience.md was appended",
            "title": "Experience Appended",
            "type": "boolean"
          }
        },
        "required": [
          "summary",
          "iter_num",
          "parent_strategy_id",
          "guidance"
        ],
        "title": "SummarizerResult",
        "type": "object"
      }
    },
    {
      "name": "optimizer_hyperparam",
      "after": [
        "summarizer"
      ],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_text_file",
        "sub_agent"
      ],
      "model": null,
      "retries": 2,
      "result_type_name": "OptimizerResult",
      "result_type_schema": {
        "description": "optimizer_{hyperparam,structural,business} output. Self-contained.\n\nEach optimizer internally retries until success (max 5). Collector reads\nthis for fitness calculation + candidates.json update.",
        "properties": {
          "summary": {
            "title": "Summary",
            "type": "string"
          },
          "optimizer_source": {
            "enum": [
              "hyperparam",
              "structural",
              "business"
            ],
            "title": "Optimizer Source",
            "type": "string"
          },
          "iter_num": {
            "title": "Iter Num",
            "type": "integer"
          },
          "parent_strategy_id": {
            "title": "Parent Strategy Id",
            "type": "string"
          },
          "strategy_id": {
            "description": "e.g. 'iter_3_opt_hyperparam'",
            "title": "Strategy Id",
            "type": "string"
          },
          "diff_path": {
            "description": "iter_N/optimizer_<X>/diff.patch",
            "title": "Diff Path",
            "type": "string"
          },
          "train_log_path": {
            "description": "iter_N/optimizer_<X>/train.log",
            "title": "Train Log Path",
            "type": "string"
          },
          "eval_result_path": {
            "description": "iter_N/optimizer_<X>/eval_result.json",
            "title": "Eval Result Path",
            "type": "string"
          },
          "changes_path": {
            "description": "iter_N/optimizer_<X>/changes.json (declared ≤3 points)",
            "title": "Changes Path",
            "type": "string"
          },
          "changes_count": {
            "description": "Actual change count (≤MAX_CHANGE_COUNT enforced)",
            "title": "Changes Count",
            "type": "integer"
          },
          "attempts": {
            "description": "How many retries it took (1-6)",
            "title": "Attempts",
            "type": "integer"
          },
          "success": {
            "description": "True iff training succeeded with valid metric",
            "title": "Success",
            "type": "boolean"
          }
        },
        "required": [
          "summary",
          "optimizer_source",
          "iter_num",
          "parent_strategy_id",
          "strategy_id",
          "diff_path",
          "train_log_path",
          "eval_result_path",
          "changes_path",
          "changes_count",
          "attempts",
          "success"
        ],
        "title": "OptimizerResult",
        "type": "object"
      }
    },
