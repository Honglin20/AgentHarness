{
  "name": "precision-diagnostic",
  "agents": [
    {
      "name": "adapter",
      "after": [],
      "tools": [
        "bash",
        "grep",
        "glob",
        "read_file",
        "ask_user"
      ],
      "model": null,
      "retries": 3,
      "result_type_name": "ProjectAnalysis",
      "result_type_schema": {
        "description": "Structured output from the adapter agent.",
        "properties": {
          "model_class": {
            "description": "nn.Module class name (e.g. 'ResNet18')",
            "title": "Model Class",
            "type": "string"
          },
          "model_module": {
            "description": "Dotted import path relative to project root (e.g. 'models.resnet')",
            "title": "Model Module",
            "type": "string"
          },
          "model_init_args": {
            "additionalProperties": true,
            "description": "Init kwargs for the model",
            "title": "Model Init Args",
            "type": "object"
          },
          "dataset": {
            "description": "Dataset name or description (e.g. 'CIFAR-10')",
            "title": "Dataset",
            "type": "string"
          },
          "weights_path": {
            "description": "Absolute path to weights file, or 'NOT_FOUND'",
            "title": "Weights Path",
            "type": "string"
          },
          "weights_exist": {
            "description": "Whether the weights file exists on disk",
            "title": "Weights Exist",
            "type": "boolean"
          },
          "adapter_exists": {
            "default": false,
            "description": "Whether _adapter.py already exists",
            "title": "Adapter Exists",
            "type": "boolean"
          },
          "adapter_path": {
            "default": "",
            "description": "Path to existing adapter, or empty",
            "title": "Adapter Path",
            "type": "string"
          },
          "missing_info": {
            "description": "List of items that could not be auto-detected — ask the user about these",
            "items": {
              "type": "string"
            },
            "title": "Missing Info",
            "type": "array"
          },
          "summary": {
            "description": "One-sentence project description",
            "title": "Summary",
            "type": "string"
          }
        },
        "required": [
          "model_class",
          "model_module",
          "dataset",
          "weights_path",
          "weights_exist",
          "summary"
        ],
        "title": "ProjectAnalysis",
        "type": "object"
      }
    },
    {
      "name": "quant_study",
      "after": [
        "adapter"
      ],
      "tools": [
        "bash",
        "ask_user"
      ],
      "model": null,
      "retries": 3,
      "result_type_name": "StudyRunResult",
      "result_type_schema": {
        "$defs": {
          "ConfigSummary": {
            "properties": {
              "name": {
                "description": "Config name (e.g. 'W4A4')",
                "title": "Name",
                "type": "string"
              },
              "accuracy": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Eval accuracy",
                "title": "Accuracy"
              },
              "delta": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Accuracy delta from FP32",
                "title": "Delta"
              },
              "avg_qsnr_db": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Mean QSNR across layers",
                "title": "Avg Qsnr Db"
              },
              "avg_mse": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Mean MSE across layers",
                "title": "Avg Mse"
              }
            },
            "required": [
              "name"
            ],
            "title": "ConfigSummary",
            "type": "object"
          }
        },
        "description": "Structured output from the quant_study agent.",
        "properties": {
          "status": {
            "description": "'success' or 'error'",
            "title": "Status",
            "type": "string"
          },
          "output_dir": {
            "description": "Directory where StudyReport.save() wrote results",
            "title": "Output Dir",
            "type": "string"
          },
          "target_format": {
            "description": "The primary format being analyzed (e.g. 'int4')",
            "title": "Target Format",
            "type": "string"
          },
          "config_names": {
            "description": "All successfully run config names",
            "items": {
              "type": "string"
            },
            "title": "Config Names",
            "type": "array"
          },
          "fp32_accuracy": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "FP32 baseline accuracy",
            "title": "Fp32 Accuracy"
          },
          "configs_summary": {
            "items": {
              "$ref": "#/$defs/ConfigSummary"
            },
            "title": "Configs Summary",
            "type": "array"
          },
          "error": {
            "default": "",
            "description": "Error message if status='error'",
            "title": "Error",
            "type": "string"
          },
          "summary": {
            "description": "One-sentence result summary",
            "title": "Summary",
            "type": "string"
          }
        },
        "required": [
          "status",
          "output_dir",
          "target_format",
          "summary"
        ],
        "title": "StudyRunResult",
        "type": "object"
      }
    },
    {
      "name": "coarse_analyzer",
      "after": [
        "quant_study"
      ],
      "tools": [
        "bash"
      ],
      "model": null,
      "retries": 3,
      "result_type_name": "CoarseAnalysis",
      "result_type_schema": {
        "$defs": {
          "ConfigGap": {
            "properties": {
              "name": {
                "description": "Config name",
                "title": "Name",
                "type": "string"
              },
              "accuracy": {
                "description": "Eval accuracy",
                "title": "Accuracy",
                "type": "number"
              },
              "delta_from_fp32": {
                "description": "Accuracy difference from FP32 baseline",
                "title": "Delta From Fp32",
                "type": "number"
              }
            },
            "required": [
              "name",
              "accuracy",
              "delta_from_fp32"
            ],
            "title": "ConfigGap",
            "type": "object"
          },
          "TransformRecovery": {
            "properties": {
              "config": {
                "description": "Base config (e.g. 'W4A4')",
                "title": "Config",
                "type": "string"
              },
              "transform": {
                "description": "Transform name (e.g. 'smoothquant')",
                "title": "Transform",
                "type": "string"
              },
              "accuracy_gain": {
                "description": "Accuracy improvement from transform",
                "title": "Accuracy Gain",
                "type": "number"
              },
              "recovery_pct": {
                "description": "Percentage of gap recovered",
                "title": "Recovery Pct",
                "type": "number"
              }
            },
            "required": [
              "config",
              "transform",
              "accuracy_gain",
              "recovery_pct"
            ],
            "title": "TransformRecovery",
            "type": "object"
          },
          "WorstLayer": {
            "properties": {
              "layer": {
                "description": "Module name (e.g. 'layers.3.linear2')",
                "title": "Layer",
                "type": "string"
              },
              "avg_qsnr_db": {
                "description": "Average QSNR across configs",
                "title": "Avg Qsnr Db",
                "type": "number"
              },
              "worst_config": {
                "description": "Config where this layer is worst",
                "title": "Worst Config",
                "type": "string"
              },
              "worst_qsnr_db": {
                "description": "QSNR in worst config",
                "title": "Worst Qsnr Db",
                "type": "number"
              },
              "dominant_role": {
                "description": "'input', 'weight', or 'output'",
                "title": "Dominant Role",
                "type": "string"
              },
              "role_qsnr": {
                "additionalProperties": {
                  "type": "number"
                },
                "description": "Per-role QSNR",
                "title": "Role Qsnr",
                "type": "object"
              }
            },
            "required": [
              "layer",
              "avg_qsnr_db",
              "worst_config",
              "worst_qsnr_db",
              "dominant_role"
            ],
            "title": "WorstLayer",
            "type": "object"
          }
        },
        "description": "Structured output from the coarse_analyzer agent.\n\nMerges accuracy gap analysis + layer attribution into a single coarse pass.",
        "properties": {
          "fp32_accuracy": {
            "description": "FP32 baseline accuracy",
            "title": "Fp32 Accuracy",
            "type": "number"
          },
          "config_results": {
            "items": {
              "$ref": "#/$defs/ConfigGap"
            },
            "title": "Config Results",
            "type": "array"
          },
          "weight_degradation": {
            "description": "Accuracy loss from weight bit reduction",
            "title": "Weight Degradation",
            "type": "number"
          },
          "activation_degradation": {
            "description": "Accuracy loss from activation bit reduction",
            "title": "Activation Degradation",
            "type": "number"
          },
          "primary_bottleneck": {
            "description": "'weight', 'activation', or 'both'",
            "title": "Primary Bottleneck",
            "type": "string"
          },
          "transform_recovery": {
            "items": {
              "$ref": "#/$defs/TransformRecovery"
            },
            "title": "Transform Recovery",
            "type": "array"
          },
          "consistent_worst": {
            "description": "Layers that are worst across ALL configs",
            "items": {
              "$ref": "#/$defs/WorstLayer"
            },
            "title": "Consistent Worst",
            "type": "array"
          },
          "config_specific_worst": {
            "description": "Layers that are worst only in specific configs",
            "items": {
              "$ref": "#/$defs/WorstLayer"
            },
            "title": "Config Specific Worst",
            "type": "array"
          },
          "worst_layer_names": {
            "description": "Flat list of worst-layer names, consumed by downstream agents",
            "items": {
              "type": "string"
            },
            "title": "Worst Layer Names",
            "type": "array"
          },
          "summary": {
            "description": "One-sentence coarse analysis summary",
            "title": "Summary",
            "type": "string"
          }
        },
        "required": [
          "fp32_accuracy",
          "weight_degradation",
          "activation_degradation",
          "primary_bottleneck",
          "summary"
        ],
        "title": "CoarseAnalysis",
        "type": "object"
      }
    },
    {
      "name": "deep_dive_analyst",
      "after": [
        "coarse_analyzer"
      ],
      "tools": [
        "bash"
      ],
      "model": null,
      "retries": 3,
      "result_type_name": "DeepDiveReport",
      "result_type_schema": {
        "$defs": {
          "FormatWeakness": {
            "properties": {
              "format": {
                "description": "Format name (e.g. 'int4')",
                "title": "Format",
                "type": "string"
              },
              "issue": {
                "description": "Description of the format limitation",
                "title": "Issue",
                "type": "string"
              },
              "affected_layers": {
                "items": {
                  "type": "string"
                },
                "title": "Affected Layers",
                "type": "array"
              },
              "evidence": {
                "description": "Supporting evidence",
                "title": "Evidence",
                "type": "string"
              }
            },
            "required": [
              "format",
              "issue",
              "evidence"
            ],
            "title": "FormatWeakness",
            "type": "object"
          },
          "LayerBlockAnalysis": {
            "properties": {
              "layer": {
                "description": "Module name",
                "title": "Layer",
                "type": "string"
              },
              "config": {
                "description": "Source config",
                "title": "Config",
                "type": "string"
              },
              "weight_block_qsnr": {
                "anyOf": [
                  {
                    "additionalProperties": {
                      "type": "number"
                    },
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Per-block QSNR: {'0': 25.1, ...}",
                "title": "Weight Block Qsnr"
              },
              "worst_weight_blocks": {
                "items": {
                  "$ref": "#/$defs/UnitErrorDetail"
                },
                "title": "Worst Weight Blocks",
                "type": "array"
              },
              "weight_error_pattern": {
                "default": "",
                "description": "'concentrated', 'uniform', or 'channel-boundary'",
                "title": "Weight Error Pattern",
                "type": "string"
              },
              "activation_channel_qsnr": {
                "anyOf": [
                  {
                    "additionalProperties": {
                      "type": "number"
                    },
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Per-channel QSNR",
                "title": "Activation Channel Qsnr"
              },
              "worst_activation_channels": {
                "items": {
                  "$ref": "#/$defs/UnitErrorDetail"
                },
                "title": "Worst Activation Channels",
                "type": "array"
              },
              "activation_error_pattern": {
                "default": "",
                "description": "'outlier_channel', 'uniform', or 'feature-correlated'",
                "title": "Activation Error Pattern",
                "type": "string"
              },
              "finding": {
                "description": "One-sentence key finding for this layer",
                "title": "Finding",
                "type": "string"
              }
            },
            "required": [
              "layer",
              "config",
              "finding"
            ],
            "title": "LayerBlockAnalysis",
            "type": "object"
          },
          "LayerDistribution": {
            "properties": {
              "layer": {
                "description": "Module name",
                "title": "Layer",
                "type": "string"
              },
              "role": {
                "description": "Analyzed role: 'input' or 'weight'",
                "title": "Role",
                "type": "string"
              },
              "config": {
                "description": "Source config",
                "title": "Config",
                "type": "string"
              },
              "qsnr_db": {
                "description": "QSNR for this layer+role+config",
                "title": "Qsnr Db",
                "type": "number"
              },
              "distribution_type": {
                "description": "'zero-centered-gaussian', 'bimodal', 'outlier-heavy', etc.",
                "title": "Distribution Type",
                "type": "string"
              },
              "key_features": {
                "additionalProperties": {
                  "type": "number"
                },
                "description": "Metrics: outlier_ratio, dynamic_range_bits, kurtosis, etc.",
                "title": "Key Features",
                "type": "object"
              },
              "diagnosis": {
                "description": "Human-readable diagnosis",
                "title": "Diagnosis",
                "type": "string"
              },
              "suggestion": {
                "description": "Suggested action",
                "title": "Suggestion",
                "type": "string"
              }
            },
            "required": [
              "layer",
              "role",
              "config",
              "qsnr_db",
              "distribution_type",
              "diagnosis",
              "suggestion"
            ],
            "title": "LayerDistribution",
            "type": "object"
          },
          "UnitErrorDetail": {
            "properties": {
              "idx": {
                "description": "Block or channel index",
                "title": "Idx",
                "type": "integer"
              },
              "qsnr_db": {
                "description": "QSNR for this unit",
                "title": "Qsnr Db",
                "type": "number"
              },
              "stats": {
                "additionalProperties": {
                  "type": "number"
                },
                "description": "Unit statistics",
                "title": "Stats",
                "type": "object"
              }
            },
            "required": [
              "idx",
              "qsnr_db"
            ],
            "title": "UnitErrorDetail",
            "type": "object"
          }
        },
        "description": "Structured output from the deep_dive_analyst agent.\n\nMerges distribution profiling + block-level analysis.",
        "properties": {
          "distribution_profiles": {
            "items": {
              "$ref": "#/$defs/LayerDistribution"
            },
            "title": "Distribution Profiles",
            "type": "array"
          },
          "block_analyses": {
            "items": {
              "$ref": "#/$defs/LayerBlockAnalysis"
            },
            "title": "Block Analyses",
            "type": "array"
          },
          "format_weaknesses": {
            "items": {
              "$ref": "#/$defs/FormatWeakness"
            },
            "title": "Format Weaknesses",
            "type": "array"
          },
          "causal_summary": {
            "default": "",
            "description": "Causal analysis summary",
            "title": "Causal Summary",
            "type": "string"
          },
          "summary": {
            "description": "One-sentence deep dive summary",
            "title": "Summary",
            "type": "string"
          }
        },
        "required": [
          "summary"
        ],
        "title": "DeepDiveReport",
        "type": "object"
      }
    },
    {
      "name": "intervention_explorer",
      "after": [
        "coarse_analyzer"
      ],
      "tools": [
        "bash",
        "ask_user"
      ],
      "model": null,
      "retries": 3,
      "result_type_name": "InterventionReport",
      "result_type_schema": {
        "$defs": {
          "CombinedRecovery": {
            "properties": {
              "description": {
                "description": "Strategy description",
                "title": "Description",
                "type": "string"
              },
              "layers_modified": {
                "items": {
                  "type": "string"
                },
                "title": "Layers Modified",
                "type": "array"
              },
              "accuracy": {
                "description": "Resulting accuracy",
                "title": "Accuracy",
                "type": "number"
              },
              "gap_recovered_pct": {
                "description": "Percentage of FP32 gap recovered",
                "title": "Gap Recovered Pct",
                "type": "number"
              }
            },
            "required": [
              "description",
              "accuracy",
              "gap_recovered_pct"
            ],
            "title": "CombinedRecovery",
            "type": "object"
          },
          "LayerRecovery": {
            "properties": {
              "layer": {
                "description": "Module name",
                "title": "Layer",
                "type": "string"
              },
              "intervention": {
                "description": "'fp32_restore', 'bit_boost', 'smoothquant', 'hadamard', etc.",
                "title": "Intervention",
                "type": "string"
              },
              "accuracy_before": {
                "description": "Accuracy before intervention",
                "title": "Accuracy Before",
                "type": "number"
              },
              "accuracy_after": {
                "description": "Accuracy after intervention",
                "title": "Accuracy After",
                "type": "number"
              },
              "gap_recovered_pct": {
                "description": "Percentage of FP32 gap recovered",
                "title": "Gap Recovered Pct",
                "type": "number"
              },
              "dominant_role": {
                "description": "'input' or 'weight'",
                "title": "Dominant Role",
                "type": "string"
              }
            },
            "required": [
              "layer",
              "intervention",
              "accuracy_before",
              "accuracy_after",
              "gap_recovered_pct",
              "dominant_role"
            ],
            "title": "LayerRecovery",
            "type": "object"
          }
        },
        "description": "Structured output from the intervention_explorer agent.",
        "properties": {
          "single_layer_recovery": {
            "items": {
              "$ref": "#/$defs/LayerRecovery"
            },
            "title": "Single Layer Recovery",
            "type": "array"
          },
          "bit_boost_recovery": {
            "items": {
              "$ref": "#/$defs/LayerRecovery"
            },
            "title": "Bit Boost Recovery",
            "type": "array"
          },
          "transform_recovery": {
            "items": {
              "$ref": "#/$defs/LayerRecovery"
            },
            "title": "Transform Recovery",
            "type": "array"
          },
          "combined_recovery": {
            "items": {
              "$ref": "#/$defs/CombinedRecovery"
            },
            "title": "Combined Recovery",
            "type": "array"
          },
          "best_strategy": {
            "description": "Best strategy description",
            "title": "Best Strategy",
            "type": "string"
          },
          "summary": {
            "description": "One-sentence intervention summary",
            "title": "Summary",
            "type": "string"
          }
        },
        "required": [
          "best_strategy",
          "summary"
        ],
        "title": "InterventionReport",
        "type": "object"
      }
    },
    {
      "name": "summary_painter",
      "after": [
        "deep_dive_analyst",
        "intervention_explorer"
      ],
      "tools": [
        "bash"
      ],
      "model": null,
      "retries": 3,
      "result_type_name": "DiagnosticReport",
      "result_type_schema": {
        "$defs": {
          "ConfigAccuracy": {
            "properties": {
              "name": {
                "description": "Config name",
                "title": "Name",
                "type": "string"
              },
              "accuracy": {
                "description": "Eval accuracy",
                "title": "Accuracy",
                "type": "number"
              },
              "delta": {
                "description": "Delta from FP32",
                "title": "Delta",
                "type": "number"
              },
              "with_transform": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Best transform variant accuracy",
                "title": "With Transform"
              }
            },
            "required": [
              "name",
              "accuracy",
              "delta"
            ],
            "title": "ConfigAccuracy",
            "type": "object"
          },
          "FormatWeakness": {
            "properties": {
              "format": {
                "description": "Format name (e.g. 'int4')",
                "title": "Format",
                "type": "string"
              },
              "issue": {
                "description": "Description of the format limitation",
                "title": "Issue",
                "type": "string"
              },
              "affected_layers": {
                "items": {
                  "type": "string"
                },
                "title": "Affected Layers",
                "type": "array"
              },
              "evidence": {
                "description": "Supporting evidence",
                "title": "Evidence",
                "type": "string"
              }
            },
            "required": [
              "format",
              "issue",
              "evidence"
            ],
            "title": "FormatWeakness",
            "type": "object"
          },
          "LayerFinding": {
            "properties": {
              "layer": {
                "description": "Module name",
                "title": "Layer",
                "type": "string"
              },
              "config": {
                "description": "Config name",
                "title": "Config",
                "type": "string"
              },
              "output_qsnr": {
                "description": "Output QSNR (dB)",
                "title": "Output Qsnr",
                "type": "number"
              },
              "dominant_role": {
                "description": "'input', 'weight', or 'output'",
                "title": "Dominant Role",
                "type": "string"
              },
              "diagnosis": {
                "description": "Human-readable diagnosis",
                "title": "Diagnosis",
                "type": "string"
              },
              "worst_block_idx": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Worst Block Idx"
              },
              "worst_channel_idx": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Worst Channel Idx"
              },
              "recovery_pct": {
                "anyOf": [
                  {
