# ── Build & runtime artifacts ────────────────────────────────────────
# These are regenerable outputs (tool mirrors, bundler/webpack builds,
# per-run metrics) — never source. Project *config* (budget.json,
# baseline.json authored configs) is tracked; per-run state is not.

# Tool-output mirrors captured during agent runs
/.tool_outputs/
.bash_outputs/

# Frontend build output (regenerated by next/webpack)
frontend/out/

# Per-run metrics / session pointers written into tracked projects
.baseline_metrics.json
.nas_train_metrics.json
.domain_insights_session_path
.nas_session_pointer

# Quantization baseline experiment output (regenerable from the model)
/benchmarks/mxint-quant-baseline/
