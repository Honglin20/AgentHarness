# ── NAS workflow scratch / generated artifacts ──────────────────────
# Per-run / experiment outputs, not source. Workflow source itself
# (workflows/nas/agents/*.md, workflows/nas/helpers/*.py, cognition/) is
# tracked normally; only generated state and throwaway scratch is ignored.

# Local Claude plan scratch (per-session, not shared)
.claude/plans/

# NAS session pointer + spike/experiment scripts
.nas_session_pointer
.spike_*.py

# Captured bash command output mirrors
.bash_outputs/

# Checkpoints / model exports / training artifacts (per-run, large, regenerable)
checkpoints/
*.pt
*.onnx
onnxruntime_profile__*.json
train_metrics*.json
eval_result.json
output_worker*.json
project_analysis.json

# Editor / manual backups
*.bak

# Diagnostics copies + transient data dumps
diagnostic_copy/
diagnostic_data/

# Saved workflow sessions (runtime state)
sessions/

